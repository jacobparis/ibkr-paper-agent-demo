# Required paper account credentials and bracket prices.
TWS_USERID=replace-with-paper-username
TWS_PASSWORD=replace-with-paper-password
IBKR_ACCOUNT_ID=DU_REPLACE_ME
IBKR_ENTRY_LIMIT=
IBKR_TAKE_PROFIT_LIMIT=
IBKR_STOP_LOSS_PRICE=

# Optional intent overrides.
# IBKR_SYMBOL=AAPL
# IBKR_QUANTITY=1
# IBKR_ENTRY_TIF=GTD
# IBKR_ENTRY_TTL_SECONDS=900
# IBKR_OUTSIDE_RTH=true
# IBKR_SANDBOX_NAME=ibkr-paper-agent

# Required only for the default durable GTC entry.
# IBKR_ALLOW_DURABLE_ENTRY=YES_I_UNDERSTAND_THIS_PAPER_ENTRY_REMAINS_ACTIVE_UNTIL_FILLED_OR_CANCELLED

# Required only with IBKR_OUTSIDE_RTH=true.
# IBKR_ALLOW_OUTSIDE_RTH=YES_I_UNDERSTAND_THIS_PAPER_ORDER_CAN_EXECUTE_OUTSIDE_REGULAR_HOURS

# Supply these as one-run command prefixes after user confirmation. Do not save
# them here.
# IBKR_AUTH_READY=YES_I_AM_READY_TO_COMPLETE_IBKR_AUTH_IN_MY_BROWSER
# IBKR_ALLOW_ORDER_SUBMISSION=YES_I_UNDERSTAND_THIS_SUBMITS_A_PAPER_BRACKET_ORDER
