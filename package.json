{
  "name": "ibkr-sandbox-agent-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "Paper-only IBKR agent demo with Vercel Sandbox validation scripts.",
  "scripts": {
    "test": "bun test && python3 -m unittest discover -s test -p 'test_*.py'",
    "typecheck": "bunx tsc",
    "validate:docker": "bun scripts/validate-vercel-docker.ts",
    "validate:ibgateway-image": "bun scripts/validate-ib-gateway-image.ts",
    "validate:ondemand-worker": "bun scripts/validate-ondemand-worker.ts",
    "worker:intent": "bun scripts/create-paper-intent.ts",
    "worker:remote": "bun scripts/run-ondemand-worker.ts"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@vercel/sandbox": "^2.1.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "^5.8.3"
  }
}
